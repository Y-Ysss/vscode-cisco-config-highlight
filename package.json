{
  "name": "cisco-config-highlight",
  "displayName": "Cisco Config Highlight",
  "description": "Cisco device configuration Syntax Highlighting for Visual Studio Code.",
  "version": "0.8.0",
  "publisher": "Y-Ysss",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Y-Ysss/vscode-cisco-config-highlight.git"
  },
  "engines": {
    "vscode": "^1.63.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "images/icon.png",
  "activationEvents": [
    "onLanguage:cisco"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cisco",
        "aliases": [
          "Cisco Config",
          "cisco"
        ],
        "extensions": [
          ".cisco",
          ".config"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cisco",
        "scopeName": "source.cisco",
        "path": "./syntaxes/cisco.tmLanguage.json"
      }
    ],
    "configuration": [
      {
        "title": "Cisco Config Highlight",
        "properties": {
          "cisco-config-highlight.outline.showSymbolsInOutlinePanel": {
            "type": "boolean",
            "default": false,
            "description": "%configuration.properties.showSymbolsInOutlinePanel.description%"
          },
          "cisco-config-highlight.outline.symbolsList": {
            "type": "object",
            "properties": {
              "command": {
                "type": "boolean",
                "default": true,
                "description": "%configuration.properties.symbols.command.description%"
              },
              "ip_vrf": {
                "type": "boolean",
                "default": true,
                "description": "%configuration.properties.symbols.ipVrf.description%"
              },
              "router_bgp": {
                "type": "boolean",
                "default": true,
                "description": "%configuration.properties.symbols.routerBgp.description%"
              },
              "address_family": {
                "type": "boolean",
                "default": true,
                "description": "%configuration.properties.symbols.addressFamily.description%"
              },
              "class_map": {
                "type": "boolean",
                "default": true,
                "description": "%configuration.properties.symbols.classMap.description%"
              },
              "policy_map": {
                "type": "boolean",
                "default": true,
                "description": "%configuration.properties.symbols.policyMap.description%"
              },
              "interface": {
                "type": "boolean",
                "default": true,
                "description": "%configuration.properties.symbols.interface.description%"
              },
              "sub_interface": {
                "type": "boolean",
                "default": true,
                "description": "%configuration.properties.symbols.subInterface.description%"
              },
              "route_map": {
                "type": "boolean",
                "default": true,
                "description": "%configuration.properties.symbols.routeMap.description%"
              },
              "ip_prefix_list": {
                "type": "boolean",
                "default": true,
                "description": "%configuration.properties.symbols.ipPrefixList.description%"
              }
            },
            "additionalProperties": false,
            "default": {
              "command": true,
              "ip_vrf": true,
              "router_bgp": true,
              "address_family": true,
              "class_map": true,
              "policy_map": true,
              "interface": true,
              "sub_interface": true,
              "route_map": true,
              "ip_prefix_list": true
            },
            "description": "%configuration.properties.showEnableDisableSymbols.description%"
          },
          "cisco-config-highlight.outline.maxFileSizeForFullScan": {
            "type": "number",
            "default": 10485760,
            "description": "%configuration.properties.outline.maxFileSizeForFullScan.description%"
          },
          "cisco-config-highlight.diagnostics.allowNonContiguousMask": {
            "type": "boolean",
            "default": false,
            "description": "%configuration.properties.diagnostics.allowNonContiguousMask.description%"
          },
          "cisco-config-highlight.diagnostics.enabled": {
            "type": "boolean",
            "default": true,
            "description": "%configuration.properties.diagnostics.enabled.description%"
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node -e \"require('node:fs').rmSync('out',{recursive:true,force:true})\" && rollup --config rollup.config.ts --configPlugin esbuild",
    "watch": "tsc -watch -p ./",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome format ./src",
    "format:fix": "biome format --write ./src",
    "check": "biome check ./src",
    "check:fix": "biome check --write ./src",
    "test": "vitest",
    "bench:outline": "vitest bench src/providers/outline/outlineExtractor.test.bench.ts --run",
    "bench:diagnostics": "vitest bench src/providers/diagnostics/diagnostics.test.bench.ts --run",
    "package": "vsce package",
    "publish:vsce": "vsce publish --packagePath ./*.vsix",
    "publish:vsce:pre-release": "vsce publish --packagePath ./*.vsix --pre-release",
    "publish:ovsx": "ovsx publish ./*.vsix",
    "publish:ovsx:pre-release": "ovsx publish ./*.vsix --pre-release"
  },
  "dependencies": {
    "semver": "^7.5.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.4",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/node": "^25.6.0",
    "@types/semver": "^7.5.2",
    "@types/vscode": "^1.52.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/vsce": "^3.9.1",
    "ovsx": "^0.10.12",
    "rollup": "^4.60.3",
    "rollup-plugin-esbuild": "^6.2.1",
    "typescript": "^5.4.3",
    "vitest": "^4.1.5"
  }
}
