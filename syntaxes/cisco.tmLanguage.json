{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Cisco Config",
  "patterns": [
    {
      "include": "#unused"
    },
    {
      "include": "#comment"
    },
    {
      "include": "#group"
    },
    {
      "include": "#interface_type"
    },
    {
      "include": "#interface"
    },
    {
      "include": "#vrf"
    },
    {
      "include": "#string"
    },
    {
      "include": "#acl"
    },
    {
      "include": "#crypto"
    },
    {
      "include": "#event_manager"
    },
    {
      "include": "#address"
    },
    {
      "include": "#command_hostname"
    },
    {
      "include": "#numeric"
    },
    {
      "comment": "bgp must be placed after address. {neighbor [peer-group-name or ip-address]}",
      "include": "#bgp"
    },
    {
      "include": "#keyword"
    },
    {
      "include": "#param1"
    },
    {
      "include": "#param1"
    }
  ],
  "repository": {
    "keyword": {
      "patterns": [
        {
          "name": "keyword.other.config-keyword.vlan.cisco",
          "match": "(^|\\s)(protocol-vlan|mac-vlan|dot1q-tunnel|dot1[Qq])(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.switchport-mode.access.cisco",
          "match": "(^|\\s)(access)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.switchport-mode.trunk.cisco",
          "match": "(^|\\s)(trunk)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.switchport-mode.dynamic.cisco",
          "match": "(^|\\s)(dynamic\\s(auto|desirable))(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.add-remove.add.cisco",
          "match": "(^|\\s)(add)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.add-remove.remove.cisco",
          "match": "(^|\\s)(remove)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.add-remove.except.cisco",
          "match": "(^|\\s)(except)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.allowed-native.cisco",
          "match": "(^|\\s)(allowed|native)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.any-all.any.cisco",
          "match": "(^|\\s)(any)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.any-all.all.cisco",
          "match": "(^|\\s)(all)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.permit-deny.permit.cisco",
          "match": "(^|\\s)(permit)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.permit-deny.deny.cisco",
          "match": "(^|\\s)(deny)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.status.up.cisco",
          "match": "(^|\\s)([Uu]p)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.status.down.cisco",
          "match": "(^|\\s)([Dd]own)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.status.deleted.cisco",
          "match": "(^|\\s)([Dd]eleted)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.status.administratively-down.cisco",
          "match": "(^|\\s)([Aa]dministratively(-down)?)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.match.any.cisco",
          "match": "(^|\\s)(match-any)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.match.all.cisco",
          "match": "(^|\\s)(match-all)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.in-out.in.cisco",
          "match": "(^|\\s)(in)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.in-out.out.cisco",
          "match": "(^|\\s)(out)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.input-output.input.cisco",
          "match": "(^|\\s)(input)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.input-output.output.cisco",
          "match": "(^|\\s)(output)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.inside-outside.inside.cisco",
          "match": "(^|\\s)(inside)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.inside-outside.outside.cisco",
          "match": "(^|\\s)(outside)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.enable-disable.enable.cisco",
          "match": "(^|\\s)(enabled?)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.enable-disable.disable.cisco",
          "match": "(^|\\s)(disabled?)(?=\\s|$)"
        },
        {
          "name": "keyword.other.config-keyword.shutdown.cisco",
          "match": "(^|\\s)(shutdown)(?=\\b|$)"
        }
      ]
    },
    "interface_type": {
      "patterns": [
        {
          "include": "#ethernet"
        },
        {
          "include": "#wireless"
        },
        {
          "include": "#loopback"
        },
        {
          "include": "#port-channel"
        },
        {
          "include": "#tunnel"
        },
        {
          "include": "#vlan"
        },
        {
          "include": "#null"
        },
        {
          "include": "#serial"
        },
        {
          "include": "#cellular"
        },
        {
          "include": "#virtual-template"
        },
        {
          "include": "#dialer"
        },
        {
          "include": "#async"
        },
        {
          "include": "#bri"
        },
        {
          "include": "#bvi"
        },
        {
          "include": "#bdi"
        },
        {
          "include": "#nvi"
        },
        {
          "include": "#vmi"
        },
        {
          "include": "#vasileft"
        },
        {
          "include": "#vasiright"
        },
        {
          "include": "#app-gigabitethernet"
        },
        {
          "include": "#management"
        }
      ],
      "repository": {
        "ethernet": {
          "name": "entity.name.class.interface.ethernet.cisco",
          "match": "\\b(([Ff]ast|([Ff]ive|[Tt]en|[Tt]wenty[Ff]ive|[Ff](orty|ifty)|([Tt]wo)?[Hh]undred)?[Gg](ig)?(abit)?)[Ee](th(ernet)?)?|[Ee]th(ernet)?|Fa|Gi|Te|Fo|Fi)(((\\d+[\\./])*)?\\d+(\\.\\d+)?)?\\b"
        },
        "wireless": {
          "name": "entity.name.class.interface.wireless.cisco",
          "match": "\\b([Dd]ot11[Rr]adio)(([0-1]([\\./]\\d)?(\\.\\d+)?)\\b(\\.\\d+)?)?\\b"
        },
        "loopback": {
          "name": "entity.name.class.interface.loopback.cisco",
          "match": "\\b([Ll]oopback|Lo)(\\d+)?\\b"
        },
        "port-channel": {
          "name": "entity.name.class.interface.portchannel.cisco",
          "match": "\\b([Pp]ort-?[Cc]hannel|Po)(12[0-8]|1[0-1][0-9]|[1-9][0-9]|[1-9])?\\b"
        },
        "tunnel": {
          "name": "entity.name.class.interface.tunnel.cisco",
          "match": "\\b([Tt]unnel|Tu)(\\d+)?\\b"
        },
        "vlan": {
          "name": "entity.name.class.interface.vlan.cisco",
          "match": "\\b(VLAN|[Vv]lan)(409[0-4]|40[0-8][0-9]|[1-3][0-9]{3}|[1-9][0-9]{1,2}|[1-9])?\\b"
        },
        "null": {
          "name": "entity.name.class.interface.null.cisco",
          "match": "\\b([Nn]ull)(\\d+)?\\b"
        },
        "serial": {
          "name": "entity.name.class.interface.serial.cisco",
          "match": "\\b([Ss]erial)(((\\d+[\\./])*)?\\d+(\\.\\d+)?)?\\b"
        },
        "cellular": {
          "name": "entity.name.class.interface.cellular.cisco",
          "match": "\\b([Cc]ellular)(((\\d+[\\./])*)?\\d+(\\.\\d+)?)?\\b"
        },
        "virtual-template": {
          "name": "entity.name.class.interface.virtual-template.cisco",
          "match": "\\b([Vv]irtual-[Tt]emplate)(\\d+)?\\b"
        },
        "dialer": {
          "name": "entity.name.class.interface.dialer.cisco",
          "match": "\\b([Dd]ialer)(\\d+)?\\b"
        },
        "async": {
          "name": "entity.name.class.interface.async.cisco",
          "match": "\\b([Aa]sync)(\\d+)?\\b"
        },
        "bri": {
          "name": "entity.name.class.interface.bri.cisco",
          "match": "\\b(BRI)(\\d+)?\\b"
        },
        "bvi": {
          "name": "entity.name.class.interface.bvi.cisco",
          "match": "\\b(BVI)(\\d+)?\\b"
        },
        "bdi": {
          "name": "entity.name.class.interface.bdi.cisco",
          "match": "\\b(BDI|[Bb]ridge-?[Dd]omain)(\\d+)?\\b"
        },
        "nvi": {
          "name": "entity.name.class.interface.nvi.cisco",
          "match": "(?i)\\b(nvi)(\\d+)?\\b"
        },
        "vmi": {
          "name": "entity.name.class.interface.vmi.cisco",
          "match": "(?i)\\b(vmi)(\\d+)?\\b"
        },
        "vasileft": {
          "name": "entity.name.class.interface.vasileft.cisco",
          "match": "\\b([Vv]asi[Ll]eft)(\\d+)?\\b"
        },
        "vasiright": {
          "name": "entity.name.class.interface.vasiright.cisco",
          "match": "\\b([Vv]asi[Rr]ight)(\\d+)?\\b"
        },
        "app-gigabitethernet": {
          "name": "entity.name.class.interface.app-gigabitethernet.cisco",
          "match": "\\b(App[Gg](ig)?(abit)?)([Ee](th(ernet)?)?)?(((\\d+[\\./])*)?\\d+(\\.\\d+)?)?\\b"
        },
        "management": {
          "name": "entity.name.class.interface.management.cisco",
          "match": "\\b(Management|[Mm]gmt)((\\d+[\\./])*)?(\\d+)?\\b"
        }
      }
    },
    "numeric": {
      "patterns": [
        {
          "include": "#integer"
        },
        {
          "include": "#hex"
        }
      ],
      "repository": {
        "hex": {
          "name": "constant.numeric.hex.cisco",
          "match": "\\b(0x)?[0-9A-F]{2}+?\\b"
        },
        "integer": {
          "name": "constant.numeric.integer.cisco",
          "match": "\\b-?\\d+\\b"
        }
      }
    },
    "comment": {
      "patterns": [
        {
          "name": "comment.line.config.cisco",
          "match": "[!#].*"
        }
      ]
    },
    "address": {
      "patterns": [
        {
          "include": "#cidr"
        },
        {
          "include": "#ipv4-full"
        },
        {
          "include": "#ipv6-condensed"
        },
        {
          "include": "#ipv6-full"
        },
        {
          "include": "#mac"
        }
      ],
      "repository": {
        "cidr": {
          "name": "keyword.other.address.ipv4.cidr.cisco",
          "match": "\\b((25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\.){3}(25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])/(\\d|[1-2]\\d|3[0-2])\\b"
        },
        "ipv4-full": {
          "name": "keyword.other.address.ipv4.full.cisco",
          "match": "\\b((25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\.){3}(25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\b"
        },
        "ipv6-condensed": {
          "name": "keyword.other.address.ipv6.condensed.cisco",
          "match": "\\b(([0-9a-fA-F]{1,4}:){6}(:[0-9a-fA-F]{1,4}|((25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)(\\.(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)){3})|:))|(([0-9a-fA-F]{1,4}:){5}(((:[0-9a-fA-F]{1,4}){1,2})|:((25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)(\\.(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)){3})|:))|(([0-9a-fA-F]{1,4}:){4}(((:[0-9a-fA-F]{1,4}){1,3})|((:[0-9a-fA-F]{1,4})?:((25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)(\\.(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)){3}))|:))|(([0-9a-fA-F]{1,4}:){3}(((:[0-9a-fA-F]{1,4}){1,4})|((:[0-9a-fA-F]{1,4}){0,2}:((25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)(\\.(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)){3}))|:))|(([0-9a-fA-F]{1,4}:){2}(((:[0-9a-fA-F]{1,4}){1,5})|((:[0-9a-fA-F]{1,4}){0,3}:((25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)(\\.(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)){3}))|:))|(([0-9a-fA-F]{1,4}:){1}(((:[0-9a-fA-F]{1,4}){1,6})|((:[0-9a-fA-F]{1,4}){0,4}:((25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)(\\.(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)){3}))|:))|(:(((:[0-9a-fA-F]{1,4}){1,7})|((:[0-9a-fA-F]{1,4}){0,5}:((25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)(\\.(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)){3}))|:))\\b"
        },
        "ipv6-full": {
          "name": "keyword.other.address.ipv6.full.cisco",
          "match": "\\b([0-9a-fA-F]{1,4}:){7}[0-9a-fA-F]{1,4}\\b"
        },
        "mac": {
          "patterns": [
            {
              "name": "keyword.other.address.mac.cisco",
              "match": "\\b([a-fA-F0-9]{2}[:.-]?){5}[a-fA-F0-9]{2}\\b",
              "comment": "Matches Standard MAC addresses in formats like 00:1A:2B:3C:4D:5E, 00-1A-2B-3C-4D-5E, or 001A.2B3C.4D5E"
            },
            {
              "name": "keyword.other.address.mac.cisco",
              "match": "\\b([a-fA-F0-9]{4}\\.?){2}[a-fA-F0-9]{4}\\b",
              "comment": "Matches Cisco dotted MAC addresses in the format 001A.2B3C.4D5E"
            }
          ]
        }
      }
    },
    "command_hostname": {
      "patterns": [
        {
          "name": "meta.function-call.command_hostname.user-mode.cisco",
          "match": "^(?!\\s)[0-9a-zA-Z\\-]+(\\(.*\\))?#"
        },
        {
          "name": "meta.function-call.command_hostname.privileged-mode.cisco",
          "match": "^(?!\\s)[0-9a-zA-Z\\-]+(\\(.*\\))?>"
        }
      ]
    },
    "param1": {
      "patterns": [
        {
          "name": "punctuation.config-param.first.cisco",
          "match": "(?<=^\\s*?)\\S+"
        }
      ]
    },
    "vrf": {
      "patterns": [
        {
          "comment": "((?<=vrf\\s)(?!.*forwarding)|(?<=vrf\\sforwarding\\s))\\S+",
          "match": "(vrf)\\s((forwarding|definition|context|member)\\s)?(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.class.vrf.declaration.cisco"
            },
            "4": {
              "name": "entity.name.tag.vrf.vrf-name.cisco"
            }
          }
        }
      ]
    },
    "string": {
      "patterns": [
        {
          "include": "#hostname"
        },
        {
          "include": "#description"
        },
        {
          "include": "#remark"
        },
        {
          "include": "#domain-name"
        },
        {
          "include": "#username"
        },
        {
          "include": "#name"
        },
        {
          "include": "#logging-system-message"
        },
        {
          "include": "#password"
        },
        {
          "include": "#secret"
        },
        {
          "include": "#key-string"
        },
        {
          "include": "#role"
        },
        {
          "include": "#banner"
        }
      ],
      "repository": {
        "description": {
          "match": "(?<=(description|Description:))\\s(.*)$",
          "name": "string.other.description.cisco"
        },
        "remark": {
          "match": "(?<=remark)\\s(.*)$",
          "name": "string.other.remark.cisco"
        },
        "hostname": {
          "match": "(?<=hostname\\s)[0-9a-zA-Z\\-]+\\b",
          "name": "entity.name.tag.config-string.hostname.cisco"
        },
        "domain-name": {
          "match": "(?<=ip\\sdomain[\\s-]name\\s)\\S+\\b",
          "name": "entity.name.tag.config-string.domain-name.cisco"
        },
        "username": {
          "match": "(?<=username\\s)(\\S+)\\b",
          "name": "entity.name.tag.config-string.username.cisco"
        },
        "name": {
          "match": "(?<=name\\s)(\\S+)\\b",
          "name": "entity.name.tag.config-string.name.cisco"
        },
        "logging-system-message": {
          "match": "(?<=%)\\S+-\\d-\\S+(?=:)",
          "name": "entity.name.tag.config-string.logging-system-message.cisco"
        },
        "role": {
          "match": "(?<=role\\s)(\\S+)\\b",
          "name": "entity.name.tag.config-string.role.cisco"
        },
        "password": {
          "match": "(?<=password\\s\\d+\\s)(\\S+)(?=\\s|$)",
          "name": "string.other.password.cisco"
        },
        "secret": {
          "match": "(?<=secret\\s\\d+\\s)(\\S+)(?=\\s|$)",
          "name": "string.other.secret.cisco"
        },
        "key-string": {
          "patterns": [
            {
              "match": "(?<=key-string\\s)(?!\\d+)(\\S+)\\b",
              "name": "string.other.key-string.cisco"
            },
            {
              "match": "(?<=key-string\\s\\d+\\s)(\\S+)\\b",
              "name": "string.other.key-string.cisco"
            }
          ]
        },
        "banner": {
          "begin": "(?<=banner\\s+(exec|login|motd|incoming|slip-ppp)\\s+)(\\S)",
          "end": "\\2",
          "name": "comment.block.banner.cisco"
        }
      }
    },
    "bgp": {
      "patterns": [
        {
          "include": "#neighbor-peer-group"
        },
        {
          "include": "#peer-session"
        },
        {
          "include": "#peer-policy"
        },
        {
          "include": "#peer-group"
        }
      ],
      "repository": {
        "neighbor-peer-group": {
          "match": "(?<=neighbor\\s)(\\S+)\\b",
          "name": "entity.name.tag.bgp.neighbor-peer-group.name.cisco"
        },
        "peer-session": {
          "match": "(?<=peer-session\\s)(\\S+)\\b",
          "name": "entity.name.tag.bgp.peer-session.name.cisco"
        },
        "peer-policy": {
          "match": "(?<=peer-policy\\s)(\\S+)\\b",
          "name": "entity.name.tag.bgp.peer-policy.name.cisco"
        },
        "peer-group": {
          "match": "(?<=peer-group\\s)(\\S+)\\b",
          "name": "entity.name.tag.bgp.peer-group.name.cisco"
        }
      }
    },
    "group": {
      "patterns": [
        {
          "include": "#class"
        },
        {
          "include": "#service-policy"
        },
        {
          "include": "#policy-map"
        },
        {
          "include": "#class-map"
        },
        {
          "include": "#route-map"
        },
        {
          "include": "#prefix-list"
        },
        {
          "include": "#object-group"
        },
        {
          "include": "#pool"
        },
        {
          "include": "#policy-list"
        },
        {
          "include": "#traffic-filter"
        },
        {
          "include": "#community"
        },
        {
          "include": "#wireless_ssid"
        }
      ],
      "repository": {
        "class": {
          "match": "(?<=class\\s(.*\\s)?)(\\S+)$",
          "name": "entity.name.tag.group.class.name.cisco"
        },
        "service-policy": {
          "match": "(?<=service-policy\\s(.*\\s)?)(\\S+)$",
          "name": "entity.name.tag.group.service-policy.name.cisco"
        },
        "policy-map": {
          "match": "(?<=policy-map\\s(.*\\s)?)(\\S+)$",
          "name": "entity.name.tag.group.policy-map.name.cisco"
        },
        "class-map": {
          "match": "(?<=class-map\\s(.*\\s)?)(\\S+)$",
          "name": "entity.name.tag.group.class-map.name.cisco"
        },
        "route-map": {
          "match": "(?<=route-map\\s)(\\S+)\\b",
          "name": "entity.name.tag.group.route-map.name.cisco"
        },
        "prefix-list": {
          "match": "(?<=prefix-list\\s)(\\S+)\\b",
          "name": "entity.name.tag.group.prefix-list.name.cisco"
        },
        "object-group": {
          "match": "(?<=object-group\\s)((service|network)\\s)?(\\S+)\\b",
          "captures": {
            "2": {
              "name": "keyword.other.group.object-group.type.cisco"
            },
            "3": {
              "name": "entity.name.tag.group.object-group.name.cisco"
            }
          }
        },
        "pool": {
          "match": "(?<=\\bpool\\s)(\\S+)\\b",
          "name": "entity.name.tag.group.pool.name.cisco"
